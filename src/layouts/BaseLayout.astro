---
// Self-hosted variable fonts. Replaces two render-blocking round trips to
// fonts.googleapis.com + fonts.gstatic.com. Subsets are unicode-range gated,
// so only the latin file is ever fetched. No `ital` axis is loaded — matching
// the previous Google Fonts request, where italic was already synthesized.
import '@fontsource-variable/dm-sans/wght.css';
import '@fontsource-variable/space-grotesk/wght.css';
import dmSansWoff2 from '@fontsource-variable/dm-sans/files/dm-sans-latin-wght-normal.woff2?url';
import groteskWoff2 from '@fontsource-variable/space-grotesk/files/space-grotesk-latin-wght-normal.woff2?url';
import '../styles/global.css';

import { SITE, VERIFY, ANALYTICS } from '../data/site';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyCta from '../components/StickyCta.astro';

interface Props {
  title: string;
  description: string;
  /** Path (leading slash) or absolute URL for canonical + og:url. */
  canonical?: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  bodyClass?: string;
  robots?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  hideStickyCta?: boolean;
  /** Path of the LCP image for this route. Preloaded at high priority. */
  preloadImage?: string;
}

const {
  title,
  description,
  canonical = Astro.url.pathname,
  ogType = 'website',
  ogImage = SITE.ogImage,
  ogImageAlt = 'Artifact Digital — digital innovation agency',
  bodyClass = '',
  robots = 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1',
  jsonLd,
  hideStickyCta = false,
  preloadImage,
} = Astro.props;

const abs = (p: string) => (p.startsWith('http') ? p : `${SITE.url}${p.startsWith('/') ? '' : '/'}${p}`);
const canonicalUrl = abs(canonical);
const ogImageUrl = abs(ogImage);
const graphs = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {/* Marks that JS is available BEFORE first paint, so the reveal animations
        can hide content only when they can also un-hide it. Without JS the page
        renders fully — no blank screen, and the LCP text isn't gated. */}
    <script is:inline>document.documentElement.classList.add('js');</script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={robots} />
    <meta name="author" content="Artifact Digital" />
    <meta name="theme-color" content="#0b0b0b" />

    <!-- Search engine verification (renders only once a token is set) -->
    {VERIFY.google && <meta name="google-site-verification" content={VERIFY.google} />}
    {VERIFY.bing && <meta name="msvalidate.01" content={VERIFY.bing} />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Artifact Digital" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/png" href="/brand_assets/favicon.png" />
    <link rel="apple-touch-icon" href="/brand_assets/apple-touch-icon.png" />
    {/* Preload the two fonts actually used above the fold, so text swaps in
        immediately rather than after the CSS is parsed and discovered. */}
    <link rel="preload" as="font" type="font/woff2" href={dmSansWoff2} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={groteskWoff2} crossorigin />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}

    {graphs.map((g) => (
      <script type="application/ld+json" set:html={JSON.stringify(g).replace(/</g, '\\u003c')} />
    ))}
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <div class="cursor" aria-hidden="true"></div>
    <div class="cursor-dot" aria-hidden="true"></div>

    <Header />

    <main id="main">
      <slot />
      <Footer />
    </main>

    {!hideStickyCta && <StickyCta />}

    <script>
      import '../scripts/main.js';
    </script>

    <!-- Analytics: opt-in via src/data/site.ts, nothing loads until enabled -->
    {ANALYTICS.vercel && (
      <Fragment>
        <script is:inline defer src="/_vercel/insights/script.js"></script>
        <script is:inline defer src="/_vercel/speed-insights/script.js"></script>
      </Fragment>
    )}
    {ANALYTICS.ga4 && (
      <Fragment>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ANALYTICS.ga4}`}></script>
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${ANALYTICS.ga4}');`}></script>
      </Fragment>
    )}
  </body>
</html>
