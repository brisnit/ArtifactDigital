---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { SITE, orgNode, breadcrumb, CTA } from '../data/site';
import { responsive } from '../lib/responsive';

export const getStaticPaths = (async () => {
  const cases = await getCollection('work');
  return cases.map((entry) => ({ params: { case: entry.id }, props: { entry } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const d = entry.data;
const path = `/${entry.id}`;
const feature = await responsive(d.feature?.image);
const story = await responsive(d.storyImage);

const caseNode = {
  '@type': 'CreativeWork',
  '@id': `${SITE.url}${path}#case`,
  name: d.metaTitle.split(' · ')[0],
  headline: d.metaTitle.split(' · ')[0],
  description: d.description,
  url: `${SITE.url}${path}`,
  image: `${SITE.url}${d.ogImage ?? SITE.ogImage}`,
  datePublished: d.year,
  inLanguage: 'en-US',
  creator: { '@id': `${SITE.url}/#organization` },
  author: { '@id': `${SITE.url}/#organization` },
  publisher: { '@id': `${SITE.url}/#organization` },
  isPartOf: { '@id': `${SITE.url}/#website` },
};
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    caseNode,
    orgNode,
    breadcrumb([
      { name: 'Home', path: '/' },
      { name: 'Work', path: '/#work' },
      { name: d.title, path },
    ]),
  ],
};
---
<BaseLayout
  title={d.metaTitle}
  description={d.description}
  canonical={path}
  ogType="article"
  ogImage={d.ogImage ?? SITE.ogImage}
  ogImageAlt={d.metaTitle.split(' · ')[0]}
  bodyClass="case-page"
  jsonLd={jsonLd}
>
  <!-- CASE HERO -->
  <section class="case-hero">
    <div class="container">
      <a class="case-back reveal" href="/#work">
        <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
          <path d="M13 7H1M6 12 1 7l5-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        Back to work
      </a>
      <span class="eyebrow reveal"><span class="eyebrow-dot"></span>{d.heroEyebrow}</span>
      <h1 class="case-title">
        {d.titleLines.map((l) => (
          <span class:list={["reveal-line", l.italic && "italic"]}><span>{l.text}</span></span>
        ))}
      </h1>
      <p class="case-lede reveal">{d.lede}</p>
      <dl class="case-meta">
        {d.meta.map((m) => (
          <div class="reveal">
            <dt>{m.label}</dt>
            <dd>{m.value}</dd>
          </div>
        ))}
      </dl>

      {d.liveUrl && (
        <p class="case-live reveal">
          <a href={d.liveUrl} target="_blank" rel="noopener">
            See it live — {d.liveUrl.replace(/^https?:\/\//, '').replace(/\/$/, '')} ↗
          </a>
        </p>
      )}

      {d.priorRole && (
        <aside class="case-attribution reveal" id="caseAttribution">
          <p class="case-attribution__text">
            <strong>About this work:</strong>{' '}
            {d.teamWork
              ? 'led by people who now work on Artifact projects, in senior roles at a previous agency, before Artifact Digital existed.'
              : 'led by Britt Midgette in a director role at a previous agency, before founding Artifact Digital.'}{' '}
            The client is not named here; the problem, the decisions and the outcomes
            are described as they happened.
          </p>
          <button class="case-attribution__close" type="button" aria-label="Dismiss this note">
            <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
              <path d="M1 1l12 12M13 1 1 13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
            </svg>
          </button>
        </aside>
      )}
    </div>
  </section>

  <!-- FEATURED MEDIA (optional) -->
  {d.feature && (
    <section class="case-feature">
      <div class="container">
        <div class="case-feature__media reveal-card">
          {d.feature.video ? (
            <video class="case-video" data-src={d.feature.video} poster={d.feature.poster} muted loop playsinline preload="none" aria-label={d.feature.alt}></video>
          ) : (
            <img class="case-img" src={d.feature.image} alt={d.feature.alt} width={feature.width} height={feature.height} srcset={feature.srcset} sizes="(max-width: 1280px) 100vw, 1280px" loading="lazy" decoding="async" />
          )}
        </div>
        <p class="case-caption reveal">{d.feature.caption}</p>
      </div>
    </section>
  )}

  <!-- PILLARS -->
  <section class="section case-pillars">
    <div class="container">
      <header class="section-head">
        <span class="section-tag reveal"><span class="tag-dot"></span>{d.pillarsTag}</span>
        <h2 class="section-heading reveal-line"><span>{d.pillarsHeading}</span></h2>
      </header>
      <div class="pillar-grid">
        {d.pillars.map((p, i) => (
          <article class="pillar reveal-card">
            <span class="pillar__num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- STORY -->
  <section class="section case-story">
    <div class:list={["container", "case-story__grid", !d.storyImage && "case-story__grid--solo"]}>
      <div class="case-story__copy">
        <span class="section-tag reveal"><span class="tag-dot"></span>{d.storyTag}</span>
        <h2 class="case-story__heading">
          {d.storyHeadingLines.map((l) => (
            <span class:list={["reveal-line", l.italic && "italic"]}><span>{l.text}</span></span>
          ))}
        </h2>
        {d.storyParagraphs.map((para) => <p class="reveal">{para}</p>)}
      </div>
      {d.storyImage && (
        <figure class="case-story__media reveal-card">
          <img src={d.storyImage} alt={d.storyImageAlt} width={story.width} height={story.height} srcset={story.srcset} sizes="(max-width: 900px) 100vw, 560px" loading="lazy" decoding="async" />
          {d.storyCaption && <figcaption>{d.storyCaption}</figcaption>}
        </figure>
      )}
    </div>
  </section>

  <!-- HIGHLIGHTS -->
  <section class="section case-highlights">
    <div class="container">
      <header class="section-head">
        <span class="section-tag reveal"><span class="tag-dot"></span>Outcomes</span>
        <h2 class="section-heading reveal-line"><span>What it delivered.</span></h2>
      </header>
      <ul class="highlight-list">
        {d.highlights.map((h, i) => (
          <li class="highlight reveal-row">
            <span class="highlight__num">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3>{h.title}</h3>
              <p>{h.body}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="section case-cta">
    <div class="container case-cta__inner">
      <h2 class="case-cta__heading reveal-line"><span>{d.ctaHeading}</span></h2>
      <div class="hero-actions">
        <Button href={CTA.primary.href} label={CTA.primary.label} variant="primary" />
        <Button href="/#work" label="See more work" variant="secondary" />
      </div>
    </div>
  </section>
</BaseLayout>
