---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SpeedModule from '../components/SpeedModule.astro';
import WorkCard from '../components/WorkCard.astro';
import { SITE, orgNode, websiteNode, CTA } from '../data/site';
import { testimonials, sectors } from '../data/testimonials';

const allWork = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
// Two proofs, kept apart: what Artifact built, and what Britt led before Artifact.
const artifactWork = allWork.filter((p) => !p.data.priorRole);
const careerWork = allWork.filter((p) => p.data.priorRole);
const liveTestimonials = testimonials.filter((t) => t.approved);

const serviceNode = {
  '@type': 'ProfessionalService',
  '@id': `${SITE.url}/#service`,
  name: SITE.name,
  url: `${SITE.url}/`,
  image: `${SITE.url}${SITE.ogImage}`,
  parentOrganization: { '@id': `${SITE.url}/#organization` },
  areaServed: 'Worldwide',
  description:
    'Senior-led digital innovation studio offering strategy, UX/UI design, AI, and engineering for ambitious brands.',
  knowsAbout: [
    'Digital strategy',
    'UX strategy',
    'UX research',
    'UX/UI design',
    'Product design',
    'AI experience design',
    'Enterprise CMS',
    'Web design and engineering',
    'Design systems',
    'Accessibility',
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Product & digital strategy' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Website design & build' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Digital products & UX' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'AI & interactive experiences' } },
    ],
  },
};

const jsonLd = { '@context': 'https://schema.org', '@graph': [orgNode, serviceNode, websiteNode] };
---
<BaseLayout
  title="Artifact Digital — Digital Innovation Agency"
  description={SITE.description}
  canonical="/"
  preloadImage="/brand_assets/hero_vid.webp"
  jsonLd={jsonLd}
>
  <!-- HERO -->
  <section class="hero" id="home">
    <div class="container hero-inner">
      <div class="hero-copy">
        <div class="hero-meta">
          <span class="eyebrow"><span class="eyebrow-dot"></span>Digital innovation studio · Est. 2021</span>
        </div>

        <h1 class="hero-heading">
          <span class="line"><span class="reveal-word"><span>We design</span></span></span>
          <span class="line"><span class="reveal-word"><span>bold digital</span></span></span>
          <span class="line italic"><span class="reveal-word"><span>experiences</span></span></span>
          <span class="line"><span class="reveal-word"><span>for ambitious brands.</span></span></span>
        </h1>

        <div class="hero-foot">
          <p class="hero-lede">
            Artifact is a senior-led digital innovation agency. We pair strategy,
            design, AI and engineering to ship products that feel precise,
            premium, and built to scale.
          </p>
          <div class="hero-actions">
            <Button href={CTA.primary.href} label={CTA.primary.label} variant="primary" />
            <Button href={CTA.work.href} label={CTA.work.label} variant="secondary" />
          </div>
        </div>
      </div>

      <div class="hero-visual">
        <video
          class="hero-video"
          data-src="/brand_assets/hero-vid2.mp4"
          data-src-mobile="/brand_assets/hero-vid2-mobile.mp4"
          poster="/brand_assets/hero_vid.webp"
          muted loop playsinline autoplay preload="metadata"
          aria-label="Artifact studio reel"
        ></video>
      </div>
    </div>
  </section>

  <!-- INTRO / MANIFESTO -->
  <section class="section intro" id="intro">
    <div class="container intro-grid">
      <div class="intro-label reveal">
        <span class="section-tag"><span class="tag-dot"></span>01 — Who we are</span>
      </div>
      <div class="intro-body">
        <h2 class="intro-heading">
          <span class="reveal-line"><span>A senior team of strategists,</span></span>
          <span class="reveal-line"><span>designers and engineers</span></span>
          <span class="reveal-line"><span>building <em>useful, beautiful</em></span></span>
          <span class="reveal-line"><span>digital products.</span></span>
        </h2>
        <p class="intro-copy reveal">
          We exist to turn ambitious ideas into real, working things — sites,
          products, identity systems and interactive experiences that move
          the business and feel unmistakably crafted.
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section services" id="services">
    <div class="container">
      <header class="section-head">
        <span class="section-tag reveal"><span class="tag-dot"></span>02 — Services</span>
        <h2 class="section-heading reveal-line"><span>What we build</span></h2>
      </header>

      <ol class="service-list">
        <li class="service-row reveal-row">
          <a class="service-row__link" href="/services/product-digital-strategy" aria-label="Product & digital strategy"></a>
          <span class="service-row__num">01</span>
          <div class="service-row__body">
            <h3 class="service-row__title">Product &amp; digital strategy</h3>
            <p class="service-row__desc">
              We translate your existing brand into clear positioning,
              narrative and visual direction for the digital products and
              experiences you're building next.
            </p>
          </div>
          <ul class="service-row__tags"><li>Strategy</li><li>Direction</li><li>Narrative</li></ul>
        </li>

        <li class="service-row reveal-row">
          <a class="service-row__link" href="/services/website-design-build" aria-label="Website design & build"></a>
          <span class="service-row__num">02</span>
          <div class="service-row__body">
            <h3 class="service-row__title">Website design &amp; build</h3>
            <p class="service-row__desc">
              Marketing sites and editorial platforms with a strong visual
              signature, accessible structure and purposeful motion.
            </p>
          </div>
          <ul class="service-row__tags"><li>Design</li><li>Development</li><li>CMS</li></ul>
        </li>

        <li class="service-row reveal-row">
          <a class="service-row__link" href="/services/digital-products-ux" aria-label="Digital products & UX"></a>
          <span class="service-row__num">03</span>
          <div class="service-row__body">
            <h3 class="service-row__title">Digital products &amp; UX</h3>
            <p class="service-row__desc">
              Product design and front-end engineering for SaaS, dashboards
              and customer-facing apps that need clarity at speed.
            </p>
          </div>
          <ul class="service-row__tags"><li>UX</li><li>UI Systems</li><li>Prototyping</li></ul>
        </li>

        <li class="service-row reveal-row">
          <a class="service-row__link" href="/services/ai-interactive-experiences" aria-label="AI & interactive experiences"></a>
          <span class="service-row__num">04</span>
          <div class="service-row__body">
            <h3 class="service-row__title">AI &amp; interactive experiences</h3>
            <p class="service-row__desc">
              AI-powered features, generative interfaces and motion-led
              experiences that make a product feel modern and alive.
            </p>
          </div>
          <ul class="service-row__tags"><li>AI</li><li>Motion</li><li>R&amp;D</li></ul>
        </li>

        <li class="service-row reveal-row">
          <a class="service-row__link" href="/services/digital-product-engineering" aria-label="Digital product engineering"></a>
          <span class="service-row__num">05</span>
          <div class="service-row__body">
            <h3 class="service-row__title">Digital product engineering</h3>
            <p class="service-row__desc">
              Enterprise websites, web and mobile apps, CMS, AI-powered products
              and interactive experiences — designed and built by one senior team.
            </p>
          </div>
          <ul class="service-row__tags"><li>Engineering</li><li>Mobile</li><li>Integration</li></ul>
        </li>
      </ol>
    </div>
  </section>

  <!-- WORK -->
  <section class="section work" id="work">
    <div class="container">
      <header class="section-head">
        <span class="section-tag reveal"><span class="tag-dot"></span>03 — Our work</span>
        <h2 class="section-heading reveal-line"><span>Built by Artifact</span></h2>
      </header>

      <div class="project-grid">
        {artifactWork.map((p) => <WorkCard entry={p} />)}
      </div>
    </div>
  </section>

  <!-- CAREER WORK -->
  <section class="section work work--career" id="career-work">
    <div class="container">
      <header class="section-head">
        <span class="section-tag reveal"><span class="tag-dot"></span>04 — Career work</span>
        <h2 class="section-heading reveal-line"><span>Our founder’s work</span></h2>
      </header>
      <p class="work-attribution reveal">
        These examples represent experience delivering digital products for leading
        organizations. To respect client confidentiality, copyright, and contractual
        obligations, branding and proprietary assets have been removed or anonymized
        while preserving the strategic thinking and design approach behind the work.
      </p>

      <div class="project-grid">
        {careerWork.map((p) => <WorkCard entry={p} />)}
      </div>
    </div>
  </section>

  <!-- SPEED TO LEARNING -->
  <SpeedModule />

  <!-- APPROACH -->
  <section class="section approach" id="approach">
    <div class="container">
      <header class="section-head">
        <span class="section-tag reveal"><span class="tag-dot"></span>04 — Approach</span>
        <h2 class="section-heading reveal-line"><span>How we work</span></h2>
      </header>

      <div class="approach-grid">
        <article class="approach-card reveal-card">
          <span class="approach-card__num">01</span>
          <h3>Discover</h3>
          <p>We surface the audience, business goals and opportunity space before sketching the first concept.</p>
        </article>
        <article class="approach-card reveal-card">
          <span class="approach-card__num">02</span>
          <h3>Design</h3>
          <p>We craft a visual system, motion language and information flow that feels modern and confident.</p>
        </article>
        <article class="approach-card reveal-card">
          <span class="approach-card__num">03</span>
          <h3>Build</h3>
          <p>We ship polished web experiences with clean code, performance-first loading and flexible editorial controls.</p>
        </article>
        <article class="approach-card reveal-card">
          <span class="approach-card__num">04</span>
          <h3>Grow</h3>
          <p>After launch we measure results and refine the experience to keep momentum and drive stronger outcomes.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="section stats">
    <div class="container stats-grid">
      <div class="stat reveal">
        <span class="stat__num" data-count="10">0</span><span class="stat__suffix">+</span>
        <p>Years I've spent leading digital strategy &amp; design</p>
      </div>
      <div class="stat reveal">
        <span class="stat__num" data-count="40">0</span><span class="stat__suffix">+</span>
        <p>Product, web and digital launches I've helped deliver</p>
      </div>
      <div class="stat reveal">
        <span class="stat__num" data-count="100">0</span><span class="stat__suffix">%</span>
        <p>Senior-led at Artifact — no handoffs, no juniors on your budget</p>
      </div>
    </div>
  </section>

  <!-- TRUST / CREDIBILITY -->
  <section class="section trust" id="trust" aria-labelledby="trust-heading">
    <div class="container">
      <header class="section-head">
        <span class="section-tag reveal"><span class="tag-dot"></span>Experience</span>
        <h2 class="section-heading reveal-line" id="trust-heading"><span>Two decades of hard-won pattern recognition</span></h2>
      </header>
      <p class="trust-lede reveal">
        Over my career I've led digital strategy and experience design for
        organizations across regulated, high-stakes industries — from healthcare and
        financial services to global retail and consumer brands. That work was
        delivered in director roles at agencies, before founding Artifact. It's the
        judgment you're hiring when you hire me.
      </p>
      <ul class="sector-list reveal" aria-label="Industries worked in">
        {sectors.map((s) => <li>{s}</li>)}
      </ul>

    </div>
  </section>

  <!-- ARTIFACT'S OWN CLIENTS -->
  {liveTestimonials.length > 0 && (
    <section class="section clients" aria-labelledby="clients-heading">
      <div class="container">
        <header class="section-head">
          <span class="section-tag reveal"><span class="tag-dot"></span>Artifact's clients</span>
          <h2 class="section-heading reveal-line" id="clients-heading"><span>In their words</span></h2>
        </header>
        <div class="testimonial-grid">
          {liveTestimonials.map((t) => (
            <figure class="testimonial reveal-card">
              <blockquote>{t.quote}</blockquote>
              <figcaption>
                <span class="testimonial__role">{t.name}</span>
                <span class="testimonial__sector">{t.role}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CONTACT -->
  <section class="section contact" id="contact">
    <div class="container contact-inner">
      <span class="section-tag reveal"><span class="tag-dot"></span>05 — Get in touch</span>

      <h2 class="contact-heading">
        <span class="reveal-line"><span>Let's translate your brand</span></span>
        <span class="reveal-line"><span>into its <em>next chapter.</em></span></span>
      </h2>

      <div class="hero-actions reveal" style="margin: 2rem 0 2.5rem;">
        <Button href={CTA.primary.href} label={CTA.primary.label} variant="primary" />
        <Button href={CTA.audit.href} label={CTA.audit.label} variant="secondary" />
      </div>

      <a class="contact-email reveal" href="mailto:hello@artifactdigital.co">
        hello@artifactdigital.co
        <svg width="22" height="22" viewBox="0 0 22 22" aria-hidden="true">
          <path d="M2 11h17M13 4l7 7-7 7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>

      <div class="contact-grid">
        <div class="contact-block reveal">
          <span class="contact-block__label">Studio</span>
          <p>San Diego, CA<br />Working with teams worldwide</p>
        </div>
        <div class="contact-block reveal">
          <span class="contact-block__label">New business</span>
          <p><a href="mailto:hello@artifactdigital.co">hello@artifactdigital.co</a></p>
        </div>
        <div class="contact-block reveal">
          <span class="contact-block__label">Follow</span>
          <p><a href={SITE.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">LinkedIn</a></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
