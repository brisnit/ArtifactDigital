---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CtaBand from '../../components/CtaBand.astro';
import WorkCard from '../../components/WorkCard.astro';
import { sectors } from '../../data/testimonials';
import { SITE, orgNode, breadcrumb } from '../../data/site';

const projects = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
const artifactWork = projects.filter((p) => !p.data.priorRole);
const careerWork = projects.filter((p) => p.data.priorRole);

const itemList = {
  '@type': 'ItemList',
  '@id': `${SITE.url}/work#list`,
  name: 'Artifact Digital case studies',
  itemListElement: projects.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.data.title,
    url: `${SITE.url}/${p.id}`,
  })),
};
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    itemList,
    orgNode,
    breadcrumb([
      { name: 'Home', path: '/' },
      { name: 'Work', path: '/work' },
    ]),
  ],
};
---
<BaseLayout
  title="Case Studies · Selected Work · Artifact Digital"
  description="Selected work from Artifact Digital — anonymized case studies in retail, education, apparel, and global food & nutrition, told through problem, approach, and outcome."
  canonical="/work"
  bodyClass="case-page work-index"
  jsonLd={jsonLd}
>
  <section class="case-hero">
    <div class="container">
      <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Work' }]} />
      <span class="eyebrow reveal"><span class="eyebrow-dot"></span>Work</span>
      <h1 class="case-title">
        <span class="reveal-line"><span>What we've built,</span></span>
        <span class="reveal-line italic"><span>and what I've led.</span></span>
      </h1>
      <p class="case-lede reveal">
        Two kinds of proof, and I keep them apart on purpose. First, products Artifact
        designed and built — small, real, and live. Then the enterprise work I led in
        senior roles at previous agencies, before Artifact existed. Both are honest;
        they're just not the same claim.
      </p>
    </div>
  </section>

  <!-- Tier 1: Artifact's own work -->
  <section class="section work">
    <div class="container">
      <header class="section-head">
        <span class="section-tag reveal"><span class="tag-dot"></span>Built by Artifact</span>
        <h2 class="section-heading reveal-line"><span>Our work</span></h2>
      </header>
      <div class="project-grid">
        {artifactWork.map((p) => <WorkCard entry={p} headingLevel="h3" />)}
      </div>
    </div>
  </section>

  <!-- Tier 2: career work, attributed -->
  <section class="section work work--career">
    <div class="container">
      <header class="section-head">
        <span class="section-tag reveal"><span class="tag-dot"></span>Career work</span>
        <h2 class="section-heading reveal-line"><span>Where I've done this before</span></h2>
      </header>
      <p class="work-attribution reveal">
        Led in senior roles at previous agencies, before Artifact existed. Not Artifact
        engagements — my track record. Clients aren't named; the problems, decisions and
        outcomes are exactly as they happened.
      </p>
      <ul class="sector-list reveal" aria-label="Industries worked in">
        {sectors.map((s) => <li>{s}</li>)}
      </ul>
      <div class="project-grid" style="margin-top: clamp(2rem, 4vw, 3rem);">
        {careerWork.map((p) => <WorkCard entry={p} headingLevel="h3" />)}
      </div>
    </div>
  </section>

  <CtaBand heading="Want to be the next case study?" />
</BaseLayout>
